# Non-secret defaults. Copy to .env and adjust as needed.

LAB_NAME=virtual-network-delay
PROVIDER=docker

# Ubuntu base image defaults.
UBUNTU_RELEASE=noble
UBUNTU_VERSION=24.04
DOCKER_UBUNTU_IMAGE=ubuntu:24.04

# Router/backend defaults.
BACKEND_PROTOCOL=http
BACKEND_HOST=
BACKEND_PORT=8080
PUBLIC_PORT=80
DELAY_MS=150
JITTER_MS=20
LOSS_PCT=0
SAMPLES=7

# Docker defaults.
DOCKER_PUBLIC_BIND=127.0.0.1
DOCKER_PUBLIC_PORT=8080

# KVM/libvirt defaults. These scripts intentionally use dedicated /24 labs.
KVM_PUBLIC_NETWORK_ADDRESS=192.168.110.0
KVM_PUBLIC_GATEWAY=192.168.110.1
KVM_PUBLIC_NETMASK=255.255.255.0
KVM_ROUTER_PUBLIC_IP=192.168.110.10
KVM_PRIVATE_NETWORK_ADDRESS=192.168.111.0
KVM_PRIVATE_GATEWAY=192.168.111.1
KVM_PRIVATE_NETMASK=255.255.255.0
KVM_ROUTER_PRIVATE_IP=192.168.111.10
KVM_BACKEND_PRIVATE_IP=192.168.111.20

# VMware Fusion/Workstation defaults. Router public IP is DHCP on vmnet8; private traffic uses vmnet1 L2.
VMWARE_PUBLIC_NETWORK=nat
VMWARE_PRIVATE_NETWORK=hostonly
VMWARE_ROUTER_PRIVATE_IP=172.31.201.10
VMWARE_BACKEND_PRIVATE_IP=172.31.201.20
VMWARE_PRIVATE_PREFIX=24
VMWARE_VMRUN_TYPE=fusion

# ESXi/vCenter defaults. Set govc credentials in your shell or a local, uncommitted .env.
# GOVC_URL=https://esxi-or-vcenter/sdk
# GOVC_USERNAME=
# GOVC_PASSWORD=
# GOVC_INSECURE=1
# GOVC_DATASTORE=datastore1
# ESXI_PUBLIC_NETWORK=VM Network
# ESXI_PRIVATE_NETWORK=vnd-private
ESXI_NETWORK_MODE=reuse
ESXI_ROUTER_PRIVATE_IP=172.31.202.10
ESXI_BACKEND_PRIVATE_IP=172.31.202.20
ESXI_PRIVATE_PREFIX=24
# ESXI_PUBLIC_VSWITCH=vSwitch0
# ESXI_PRIVATE_VSWITCH=vnd-private
# ESXI_PUBLIC_VLAN_ID=0
# ESXI_PRIVATE_VLAN_ID=0
